[node name="保存变量到文件" parent="ScrollContainer/GridContainer" unique_id=1614169380 instance=ExtResource("1_mpp5d")]
layout_mode = 2
tooltip_text = "## 将变量序列化并保存到指定文件，支持加密
## [br]参数:[br]
##   - 数据: 要保存的变量[br]
##   - 文件地址: 保存路径，默认为\"user://save_game.dat\"[br]
##   - 密码: 加密密码，为空则不加密，默认为空
## [br]返回:[br]
##   - 成功返回true，失败返回false
## [br]异常:[br]
##   - 如果JSON序列化失败，会抛出错误
##   - 如果文件无法打开，会抛出错误"
text = "保存变量到文件"
"提示的内容" = "## 将变量序列化并保存到指定文件，支持加密
## [br]参数:[br]
   - 数据: 要保存的变量[br]
   - 文件地址: 保存路径，默认为\"user://save_game.dat\"[br]
   - 密码: 加密密码，为空则不加密，默认为空
## [br]返回:[br]
   - 成功返回true，失败返回false
## [br]异常:[br]
  - 如果JSON序列化失败，会抛出错误
   - 如果文件无法打开，会抛出错误"
"插入的内容" = "引擎.文件.保存变量到文件( {\"分数\": 100, \"关卡\": 5}, \"user://game_data.dat\")  # 不加密"

[node name="读取文件到变量" parent="ScrollContainer/GridContainer" unique_id=990629021 instance=ExtResource("1_mpp5d")]
layout_mode = 2
tooltip_text = "读取文件到变量"
text = "读取文件到变量"
"提示的内容" = "## 从指定文件读取数据并反序列化为变量，支持加密
 [br]参数:[br]
   - 文件地址: 读取路径，默认为\"user://save_game.dat\"[br]
  - 密码: 解密密码，需与保存时一致，默认为空
 [br]返回:[br]
  - 成功返回变量内容，失败返回null
 [br]异常:[br]
  - 如果文件不存在或无法打开，会抛出错误
   - 如果JSON解析失败，会抛出错误
 - 如果密码错误，会抛出错误"
"插入的内容" = "var 读取的数据 = 引擎.文件.读取文件到变量(\"user://game_data.dat\")"

