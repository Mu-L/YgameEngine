layout_mode = 2
tooltip_text = "配置属性与最终效果的映射规则，支持按职业差异化计算
参数说明：
1. 规则（必填）：Dictionary类型，格式为 {属性名: {效果名: {通用: 数值, 职业名: 数值}}}
注意：配置\"通用\"代表数值与职业叠加，通用项可不配置
返回值：void，无返回值
使用示例：
角色.属性.配置属性规则({
		力量={
				攻击力={通用=1.0,战士=2.0,法师=0.0},
				生命值={通用=0.1,战士=0.5,法师=0.2}
		},
		体力={
				生命值={通用=1.0,战士=3.0,法师=1.0}
		},
		智力={
				魔力={通用=0.0,战士=0.0,法师=1.0}
		}
})"
text = "角色属性_配置属性规则"
text_overrun_behavior = 1

