custom_minimum_size = Vector2(170, 20)
layout_mode = 2
tooltip_text = "引擎.网络.字节转字符串(字节数据, \"utf8\") → UTF8格式字符串
参数:
  - 字节数据: PackedByteArray（待转换的字节数组）
