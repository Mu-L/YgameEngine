text = "ini_设置"
"提示的内容" = " 设置配置文件中指定节和键的值
 [br]参数:[br]
   - _文件: ConfigFile对象[br]
   - _节: 配置节名称[br]
   - _键: 配置键名称[br]
   - _内容: 要设置的值
 [br]返回:[br]
   - 操作是否成功（始终返回true）
[codeblock]
 引擎.配置文件.ini_设置(配置, \"General\", \"Fullscreen\", true)
[/codeblock]"
"插入的内容" = "引擎.配置文件.ini_设置(配置, \"General\", \"Fullscreen\", true)"

[node name="ini_保存配置文件" parent="ScrollContainer/GridContainer" unique_id=27143636 instance=ExtResource("1_mpp5d")]
layout_mode = 2
text = "ini_保存配置文件"
"提示的内容" = " 保存配置文件到指定路径
 [br]参数:[br]
   - _文件: ConfigFile对象[br]
   - 保存到哪里: 保存路径，默认为\"res://配置项.ini\"
 [br]返回:[br]
   - 错误码（OK表示成功，其他值表示失败）
[codeblock]
 引擎.配置文件.ini_保存配置文件(配置, \"user://saved_settings.ini\")
[/codeblock]"
"插入的内容" = "引擎.配置文件.ini_保存配置文件(配置, \"user://saved_settings.ini\")"

