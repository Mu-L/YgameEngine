return {\"请求状态\":返回值[0],
		\"网页状态码\":返回值[1],
		\"响应头\":返回值[2],
		\"内容\":返回值[3].get_string_from_utf8()
	   }
参数:
  - 请求链接: String（目标URL）
  - 请求数据: Variant（请求参数，默认空）
  - 响应头: PackedStringArray（请求头，默认空）
  - 请求类型: HTTPClient.Method（请求方法，默认METHOD_GET）
返回:
  - Dictionary（请求状态/状态码/响应头/内容）"
text = "网页请求_GET"
text_overrun_behavior = 1

