--UDP_创建客户端示例---
##初始化并获取引用
var UDP客户端: 引擎.网络类.UDP客户端
func _ready() -> void:
		UDP客户端=引擎.网络.UDP_创建客户端()
		UDP客户端.UDP_连接(\"127.0.0.1\",25555)
func _process(delta: float) -> void:
		UDP客户端.UDP_处理数据({
				\"客户端收到消息\": func(数据):
						print(\"收到-=-\",数据)
						,
				})
		
		if Input.is_action_just_pressed(\"ui_accept\"):
				var 数据=\"你好\"
				UDP客户端.UDP_发送数据(数据,\"utf8\")
				pass
[提示]
一个UDP客户端示例"
text = "字节转字符串"
text_overrun_behavior = 1

