script/source = "@tool
extends Control
##代码块,$是占位符,|是光标位置

func _on_pre_sort_children() -> void:
	
	引擎.时间.获取下一次签到的时间字符串()

	pass # Replace with functi引擎.调试.打印字典({},\"注释\")on body.
	


func _on_button_pressed() -> void:
	#引擎.调试.打印字典(代码片段)
	pass # Replace with function body.
"

