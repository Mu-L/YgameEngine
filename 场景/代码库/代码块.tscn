text_overrun_behavior = 1

[node name="装备_定制规则(唯一装备)" parent="TabContainer/装备栏/ScrollContainer/HFlowContainer" unique_id=720709844 instance=ExtResource("1_mpp5d")]
unique_name_in_owner = true
custom_minimum_size = Vector2(170, 20)
layout_mode = 2
tooltip_text = "为不可堆叠装备定制穿戴规则，适配带唯一ID的装备场景
参数说明：
1. 装备类型（必填）：String类型，要定制规则的装备类型（如：双手剑/单手剑/盾牌）
2. 处理函数（必填）：函数类型，接收道具ID、唯一ID参数，返回装备槽-[道具ID,唯一ID]的映射字典
使用示例：
