[node name="弱网发送数据" parent="TabContainer/弱网/ScrollContainer/HFlowContainer" unique_id=2025212358 instance=ExtResource("1_mpp5d")]
custom_minimum_size = Vector2(170, 20)
layout_mode = 2
tooltip_text = "#虽然可以自定义,但是不推荐用,弱网环境,大家都不一定在线
弱网.发送数据(客户端, 数据) #服务端向指定的客户端发送数据
弱网.广播数据(数据)#服务端向在线客户端广播数据
弱网.广播数据({\"类型\":\"测试\",\"文本\":\"你好胖\"},\"utf8\")
弱网.广播数据(\"你好胖\",\"utf8\")
#客户端请求服务端数据
弱网客户端.发送数据(数据) #客户端向服务端发送数据 异步
#同步异步
弱网客户端.发送数据(数据,func(响应数据):
						print(\"收到的数据?:\", 响应数据)
                )"
text = "弱网发送数据"
text_overrun_behavior = 1

