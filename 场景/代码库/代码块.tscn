##[codeblock]
 var 角度 = 引擎.数学.随机_取角度整数()      # 默认生成0-360之间的随机整数
 var 角度 = 引擎.数学.随机_取角度整数(-90)  # 生成-90-360之间的随机整数
 var 角度 = 引擎.数学.随机_取角度整数(-90, 90)  # 生成-90-90之间的随机整数
##[/codeblock]"
text = "随机_取角度整数"
text_overrun_behavior = 6

